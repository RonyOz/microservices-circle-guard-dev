def SERVICE_NAME = env.JOB_NAME.tokenize('/')[-2]          // e.g. "auth-service"
def SERVICE_DIR  = "circleguard-${SERVICE_NAME}"            // e.g. "circleguard-auth-service" (Gradle project name)
def REGISTRY     = 'registry.digitalocean.com/circleguard'
def IMAGE_TAG    = ''
def IMAGE_FULL   = ''

pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Prepare') {
            steps {
                script {
                    IMAGE_TAG  = "sha-${env.GIT_COMMIT.take(7)}"
                    IMAGE_FULL = "${REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('Test') {
            steps {
                sh """
                    docker run --rm \
                        -v "\${WORKSPACE}:/workspace" \
                        -v gradle-cache-${SERVICE_NAME}:/root/.gradle \
                        -w /workspace \
                        eclipse-temurin:21-jdk-jammy \
                        ./gradlew :services:${SERVICE_DIR}:test --no-daemon
                """
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "services/${SERVICE_DIR}/build/test-results/**/*.xml"
                }
            }
        }

        stage('Build & Push') {
            steps {
                withCredentials([string(
                    credentialsId: 'do-api-token',
                    variable: 'DO_TOKEN'
                )]) {
                    sh """
                        echo "\${DO_TOKEN}" | docker login registry.digitalocean.com \
                            -u "\${DO_TOKEN}" --password-stdin

                        DOCKER_BUILDKIT=1 docker build \
                            -f services/${SERVICE_DIR}/Dockerfile \
                            -t ${IMAGE_FULL} \
                            .

                        docker push ${IMAGE_FULL}
                    """
                }
            }
        }

        stage('Deploy: dev') {
            when { branch 'dev' }
            steps {
                build job: 'circleguard-ops/circleguard-deploy-dev',
                      parameters: [
                          string(name: 'SERVICE',   value: SERVICE_NAME),
                          string(name: 'IMAGE_TAG', value: IMAGE_TAG)
                      ],
                      wait: false
            }
        }

        stage('Deploy: stage') {
            when { branch pattern: 'release/.*', comparator: 'REGEXP' }
            steps {
                build job: 'circleguard-ops/circleguard-deploy-stage',
                      parameters: [
                          string(name: 'SERVICE',   value: SERVICE_NAME),
                          string(name: 'IMAGE_TAG', value: IMAGE_TAG)
                      ],
                      wait: false
            }
        }

        stage('Deploy: prod') {
            when { branch 'main' }
            steps {
                script {
                    def version = sh(
                        script: "git describe --tags --match 'v*' --abbrev=0 2>/dev/null || echo '1.0.0'",
                        returnStdout: true
                    ).trim().replaceAll('^v', '')

                    build job: 'circleguard-ops/circleguard-deploy-prod',
                          parameters: [
                              string(name: 'SERVICE',    value: SERVICE_NAME),
                              string(name: 'IMAGE_TAG',  value: IMAGE_TAG),
                              string(name: 'GIT_COMMIT', value: env.GIT_COMMIT),
                              string(name: 'VERSION',    value: version)
                          ],
                          wait: false
                }
            }
        }
    }

    post {
        failure {
            echo "PIPELINE FAILED — job: ${env.JOB_NAME}, branch: ${env.BRANCH_NAME}"
        }
        always {
            script {
                if (IMAGE_FULL) sh "docker rmi ${IMAGE_FULL} || true"
            }
            cleanWs()
        }
    }
}
